# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Server-Only (NICHT in NEXT_PUBLIC_ prefixen!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
NEXT_PUBLIC_MAPBOX_LIGHT_STYLE=mapbox://styles/your-username/your-light-style-id
NEXT_PUBLIC_MAPBOX_DARK_STYLE=mapbox://styles/your-username/your-dark-style-id
